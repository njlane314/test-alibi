{
  "name": "test-alibi",
  "version": "0.1.3",
  "description": "A diff-coverage tool that intersects changed executable lines with coverage data.",
  "type": "module",
  "license": "BUSL-1.1",
  "private": false,
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "test-alibi": "./lib/cli.js"
  },
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib",
    "dist",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "build:action": "ncc build src/action.ts -o dist --target es2022 --source-map --license licenses.txt"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "commander": "^14.0.1",
    "minimatch": "^10.0.3",
    "picomatch": "^4.0.3",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "@types/picomatch": "^4.0.3",
    "@vercel/ncc": "^0.38.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.33.0",
  "author": "Eidetic Research"
}
